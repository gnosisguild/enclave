# Addresses of requesters for which to show rounds in the UI. Comma separated Ethereum addresses.
VITE_E3_REQUESTERS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266,0x70997970C51812dc3A010C7d01b50e0d17dc79C8
